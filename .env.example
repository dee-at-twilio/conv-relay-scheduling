# Server url for Twilio to send webhook callbacks to
BASE_URL=https://your-ngrok-subdomain.ngrok.io

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx # to receive confirmation SMS messages
TWILIO_FLEX_WORKFLOW_SID=WWxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx # needed if transferring to Twilio Flex for human agents

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Airtable
# Create a base with these 3 tables (exact names):
#   Patients     — fields: Name, Phone, Email
#   Providers    — fields: Name, Specialty
#   Appointments — fields: Provider (link→Providers), Patient (link→Patients),
#                           Start Time, End Time, Status (single select), Notes
AIRTABLE_API_KEY=patxxxxxxxxxxxxxxxx  
AIRTABLE_BASE_ID=appxxxxxxxxxxxxxxxx

TTS_VOICE=en-US-Journey-O
TTS_LANGUAGE=en-US
TRANSCRIPTION_LANGUAGE=en-US
